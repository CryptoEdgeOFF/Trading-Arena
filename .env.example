# Copy to .env and fill in. Le serveur charge automatiquement .env via dotenv.
# Sans cles externes, les codes OTP (email + SMS) sont loggues en console et
# renvoyes dans la reponse API uniquement quand NODE_ENV != production.

# ----- Environnement -----
# Mets NODE_ENV=production en prod : desactive le compte de test, ne renvoie
# plus les codes OTP de secours et ne logge plus les OTP en clair.
NODE_ENV=

# ----- Auth admin -----
# OBLIGATOIRE : choisis un code long et secret. Aucun fallback : si vide,
# l'acces admin est desactive (fail-closed).
ADMIN_CODE=

# ----- Compte de test (bypass OTP) -----
# Le compte ARTEMTEST987 ne fonctionne qu'en dev (NODE_ENV != production) ou si
# ALLOW_TEST_LOGIN=true. NE PAS activer en production publique.
ALLOW_TEST_LOGIN=

# ----- Securite -----
# Liste blanche d'origines CORS separees par des virgules. Vide = tout autorise.
# Ex: CORS_ORIGINS=https://btf.app,https://www.btf.app
CORS_ORIGINS=
# Nombre maximal de participants par arene (defaut 2000).
MAX_ARENA_PARTICIPANTS=

# ----- Production database (Postgres) -----
# Recommande en prod: Supabase, Neon, Railway ou Render Postgres.
# Si DATABASE_URL est absent, le serveur fallback sur data/competition-platform.json (dev local).
DATABASE_URL=
# Mets DATABASE_SSL=false seulement pour un Postgres local sans SSL.
DATABASE_SSL=true

# ----- iTick TradFi (forex, indices, commodities) -----
# Source unique pour les 11 instruments TradFi : 4 forex (EUR/USD, GBP/USD,
# USD/JPY, USD/CHF), 4 commodities (GOLD, SILVER, WTI, BRENT) et 3 indices
# (SP500, NAS100, US30). Live via WS upstream + historique REST avec
# persistence Postgres (table itick_candles). Compte pro recommandé.
# Doc: https://docs.itick.org/
ITICK_TOKEN=

# En local, laisse vide: Vite proxy /api et /ws vers http://localhost:3001.
# Sur Netlify, mets l'URL publique du serveur Node persistant (Render/Railway/Fly).
# Exemple: VITE_API_URL=https://btf-arena-api.onrender.com
VITE_API_URL=

# ----- Email OTP (Resend) -----
# https://resend.com - 100 emails/jour gratuit, 3000/mois
RESEND_API_KEY=
RESEND_FROM_EMAIL="BTF Trade <onboarding@resend.dev>"
APP_NAME="BTF Trade"

# ----- SMS OTP (Twilio Verify) -----
# https://www.twilio.com/verify - service Verify dedie OTP, gere generation +
# envoi + verification + anti-fraude. ~$0.05/SMS en France.
# 1) Cree un compte Twilio (15$ de credit gratuit)
# 2) Console > Verify > Services > Create new > note le SID (commence par VAxxx)
# 3) Account Info > Account SID + Auth Token
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

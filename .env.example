# Copy to .env and fill in. Le serveur charge automatiquement .env via dotenv.
# Sans cles externes, les codes OTP (email + SMS) sont loggues en console et
# renvoyes dans la reponse API en mode dev (jamais en prod).

# ----- Auth admin -----
ADMIN_CODE=BTFb9Q6z69.9

# ----- Production database (Postgres) -----
# Recommande en prod: Supabase, Neon, Railway ou Render Postgres.
# Si DATABASE_URL est absent, le serveur fallback sur data/competition-platform.json (dev local).
DATABASE_URL=
# Mets DATABASE_SSL=false seulement pour un Postgres local sans SSL.
DATABASE_SSL=true

# ----- OANDA TradFi (stocks, indices, forex, commodities) -----
# Doc: https://developer.oanda.com/rest-live-v20/development-guide/
# Practice: https://api-fxpractice.oanda.com | Live: https://api-fxtrade.oanda.com
OANDA_API_TOKEN=
# Optionnel — auto-détecté via /v3/accounts si absent
OANDA_ACCOUNT_ID=
# practice (défaut) ou live
OANDA_ENV=practice

# En local, laisse vide: Vite proxy /api et /ws vers http://localhost:3001.
# Sur Netlify, mets l'URL publique du serveur Node persistant (Render/Railway/Fly).
# Exemple: VITE_API_URL=https://btf-arena-api.onrender.com
VITE_API_URL=

# ----- Email OTP (Resend) -----
# https://resend.com - 100 emails/jour gratuit, 3000/mois
RESEND_API_KEY=
RESEND_FROM_EMAIL="BTF Trade <onboarding@resend.dev>"
APP_NAME="BTF Trade"

# ----- SMS OTP (Twilio Verify) -----
# https://www.twilio.com/verify - service Verify dedie OTP, gere generation +
# envoi + verification + anti-fraude. ~$0.05/SMS en France.
# 1) Cree un compte Twilio (15$ de credit gratuit)
# 2) Console > Verify > Services > Create new > note le SID (commence par VAxxx)
# 3) Account Info > Account SID + Auth Token
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
